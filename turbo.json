{
	"$schema": "https://turbo.build/schema.json",
	"tasks": {
		"lint": {
			"dependsOn": [
				"^lint"
			]
		},
		"test": {
			"dependsOn": [
				"^test"
			]
		},
		"db:generate": {
			"cache": false
		},
		"build": {
			"dependsOn": [
				"db:generate",
				"^build"
			],
			"outputs": [
				".next/**",
				"dist/**"
			]
		},
		"dev": {
			"cache": false,
			"persistent": true
		}
	}
}