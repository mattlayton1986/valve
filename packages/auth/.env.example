# Provider selection (dev will start with GitHub OAuth)
AUTH_PROVIDER=github

# Used to sign/encrypt sessions/tokens (generate for local dev; never commit real secrets)
AUTH_SECRET=replace_me_with_a_long_random_string

# GitHub OAuth app credentials (local dev)
GITHUB_CLIENT_ID=replace_me
GITHUB_CLIENT_SECRET=replace_me

# Base URL where auth callbacks will run (console app later)
AUTH_BASE_URL=http://localhost:3000