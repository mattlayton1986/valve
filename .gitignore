# =============================================================================
# Dependencies (node / package managers)
# =============================================================================
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# =============================================================================
# Environment files (never commit secrets)
# =============================================================================
.env
.env.*
!**/.env.example

# =============================================================================
# Logs / debug output
# =============================================================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# =============================================================================
# OS / editor noise
# =============================================================================
.DS_Store
Thumbs.db

# =============================================================================
# Test / coverage output
# =============================================================================
coverage/

# =============================================================================
# Turbo cache
# =============================================================================
.turbo/

# =============================================================================
# Next.js build output
# =============================================================================
.next/
out/

# =============================================================================
# Common build output
# =============================================================================
dist/
build/

# =============================================================================
# Vercel
# =============================================================================
.vercel

# =============================================================================
# TypeScript build artifacts
# =============================================================================
*.tsbuildinfo
