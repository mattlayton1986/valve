# ===============================
# Auth.js / NextAuth
# ===============================

# Used to sign/encrypt session cookies
NEXTAUTH_SECRET=replace-me-with-a-random-string

# Base URL of the app (for local dev)
NEXTAUTH_URL=http://localhost:3000

# ===============================
# GitHub OAuth
# ===============================

# From your GitHub OAuth App
GH_CLIENT_ID=your-github-oauth-client-id
GH_CLIENT_SECRET=your-github-oauth-client-secret
